rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function memberPath(spaceId) {
      return /databases/$(database)/documents/familySpaces/$(spaceId)/members/$(request.auth.uid);
    }

    function isMember(spaceId) {
      return signedIn() && exists(memberPath(spaceId));
    }

    function memberRole(spaceId) {
      return get(memberPath(spaceId)).data.role;
    }

    function isOwner(spaceId) {
      return isMember(spaceId) && memberRole(spaceId) == 'owner';
    }

    function canCoordinate(spaceId) {
      return isMember(spaceId) && memberRole(spaceId) in ['owner', 'primary_caregiver'];
    }

    function canContribute(spaceId) {
      return isMember(spaceId) && memberRole(spaceId) in ['owner', 'primary_caregiver', 'helper'];
    }

    function canReceiveAssignment(spaceId, userId) {
      return exists(/databases/$(database)/documents/familySpaces/$(spaceId)/members/$(userId)) &&
        get(/databases/$(database)/documents/familySpaces/$(spaceId)/members/$(userId)).data.role in ['owner', 'primary_caregiver', 'helper'];
    }

    function validUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoUrl', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['uid', 'email', 'displayName', 'photoUrl', 'createdAt', 'updatedAt']) &&
        data.uid is string && data.uid == request.auth.uid &&
        data.email is string && data.email.size() <= 254 &&
        data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
        (data.photoUrl == null || (data.photoUrl is string && data.photoUrl.size() <= 2048)) &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validFamilySpace(data) {
      return data.keys().hasAll(['id', 'name', 'ownerUid', 'timezone', 'createdAt', 'updatedAt']) &&
        data.keys().hasOnly(['id', 'name', 'ownerUid', 'timezone', 'createdAt', 'updatedAt']) &&
        data.id is string && data.id.size() > 0 &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 60 &&
        data.ownerUid is string && data.ownerUid.size() > 0 &&
        data.timezone is string && data.timezone.size() > 0 && data.timezone.size() <= 80 &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validFamilyMember(data) {
      return data.keys().hasAll([
          'userId', 'email', 'displayName', 'relationshipLabel', 'role', 'joinedAt', 'updatedAt'
        ]) &&
        data.keys().hasOnly([
          'userId', 'email', 'displayName', 'relationshipLabel', 'role', 'joinedAt', 'updatedAt'
        ]) &&
        data.userId is string && data.userId.size() > 0 &&
        data.email is string && data.email.size() <= 254 &&
        data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
        (data.relationshipLabel == null || (data.relationshipLabel is string && data.relationshipLabel.size() <= 40)) &&
        data.role in ['owner', 'primary_caregiver', 'helper', 'viewer'] &&
        data.joinedAt is timestamp && data.updatedAt is timestamp;
    }

    function validUserSpace(spaceId, data) {
      return data.keys().hasAll([
          'familySpaceId', 'name', 'timezone', 'role', 'relationshipLabel', 'createdAt'
        ]) &&
        data.keys().hasOnly([
          'familySpaceId', 'name', 'timezone', 'role', 'relationshipLabel', 'createdAt'
        ]) &&
        data.familySpaceId == spaceId &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 60 &&
        data.timezone is string && data.timezone.size() > 0 && data.timezone.size() <= 80 &&
        data.role in ['owner', 'primary_caregiver', 'helper', 'viewer'] &&
        (data.relationshipLabel == null || (data.relationshipLabel is string && data.relationshipLabel.size() <= 40)) &&
        data.createdAt is timestamp;
    }

    function validCareProfile(spaceId, data) {
      return data.keys().hasAll([
          'id', 'linkedMemberUserId', 'fullName', 'preferredName', 'relationshipLabel', 'careNeedsSummary',
          'status', 'createdByUserId', 'createdAt', 'updatedAt'
        ]) &&
        data.keys().hasOnly([
          'id', 'linkedMemberUserId', 'fullName', 'preferredName', 'relationshipLabel', 'careNeedsSummary',
          'status', 'createdByUserId', 'createdAt', 'updatedAt'
        ]) &&
        data.id is string && data.id.size() > 0 &&
        (data.linkedMemberUserId == null || (
          data.linkedMemberUserId is string &&
          data.linkedMemberUserId == data.id &&
          exists(/databases/$(database)/documents/familySpaces/$(spaceId)/members/$(data.linkedMemberUserId))
        )) &&
        data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 80 &&
        (data.preferredName == null || (data.preferredName is string && data.preferredName.size() <= 50)) &&
        (data.relationshipLabel == null || (data.relationshipLabel is string && data.relationshipLabel.size() <= 50)) &&
        (data.careNeedsSummary == null || (data.careNeedsSummary is string && data.careNeedsSummary.size() <= 1000)) &&
        data.status in ['active', 'archived'] &&
        data.createdByUserId is string &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validCareRoutine(spaceId, data) {
      return data.keys().hasAll([
          'id', 'careProfileId', 'title', 'instructions', 'category', 'importance',
          'timeOfDay', 'daysOfWeek', 'active', 'createdByUserId', 'createdAt', 'updatedAt'
        ]) &&
        data.keys().hasOnly([
          'id', 'careProfileId', 'title', 'instructions', 'category', 'importance',
          'timeOfDay', 'daysOfWeek', 'active', 'createdByUserId', 'createdAt', 'updatedAt'
        ]) &&
        data.id is string && data.id.size() > 0 &&
        data.careProfileId is string &&
        exists(/databases/$(database)/documents/familySpaces/$(spaceId)/careProfiles/$(data.careProfileId)) &&
        data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
        data.instructions is string && data.instructions.size() > 0 && data.instructions.size() <= 2000 &&
        data.category in ['medication', 'meal', 'mobility', 'appointment', 'personal_care', 'general'] &&
        data.importance in ['routine', 'important', 'critical'] &&
        data.daysOfWeek is list && data.daysOfWeek.size() <= 7 &&
        data.daysOfWeek.hasOnly([0, 1, 2, 3, 4, 5, 6]) &&
        ((data.timeOfDay == null && data.daysOfWeek.size() == 0) ||
          (data.timeOfDay is string && data.timeOfDay.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$') && data.daysOfWeek.size() > 0)) &&
        data.active is bool &&
        data.createdByUserId is string &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validCareShift(spaceId, data) {
      return data.keys().hasAll([
          'id', 'careProfileId', 'title', 'primaryUserId', 'backupUserId', 'startsAt', 'endsAt',
          'acceptanceDeadline', 'status', 'acceptedAt', 'acceptedByUserId', 'declinedAt',
          'declinedByUserId', 'createdByUserId', 'createdAt', 'updatedAt'
        ]) &&
        data.keys().hasOnly([
          'id', 'careProfileId', 'title', 'primaryUserId', 'backupUserId', 'startsAt', 'endsAt',
          'acceptanceDeadline', 'status', 'acceptedAt', 'acceptedByUserId', 'declinedAt',
          'declinedByUserId', 'createdByUserId', 'createdAt', 'updatedAt'
        ]) &&
        data.id is string && data.id.size() > 0 &&
        data.careProfileId is string &&
        exists(/databases/$(database)/documents/familySpaces/$(spaceId)/careProfiles/$(data.careProfileId)) &&
        data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
        data.primaryUserId is string &&
        canReceiveAssignment(spaceId, data.primaryUserId) &&
        (data.backupUserId == null || (
          data.backupUserId is string && data.backupUserId != data.primaryUserId &&
          canReceiveAssignment(spaceId, data.backupUserId)
        )) &&
        data.startsAt is timestamp && data.endsAt is timestamp && data.startsAt < data.endsAt &&
        (data.acceptanceDeadline == null || (data.acceptanceDeadline is timestamp && data.acceptanceDeadline < data.startsAt)) &&
        data.status in ['pending', 'accepted', 'active', 'completed', 'declined'] &&
        (data.acceptedAt == null || data.acceptedAt is timestamp) &&
        (data.acceptedByUserId == null || data.acceptedByUserId is string) &&
        (data.declinedAt == null || data.declinedAt is timestamp) &&
        (data.declinedByUserId == null || data.declinedByUserId is string) &&
        data.createdByUserId is string &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validCueOccurrence(data) {
      return data.keys().hasAll([
          'id', 'cueId', 'careProfileId', 'shiftId', 'title', 'instructions', 'importance',
          'assignedUserId', 'scheduledAt', 'status', 'acknowledgedAt', 'snoozedUntil',
          'blockedReason', 'createdAt', 'updatedAt'
        ]) &&
        data.keys().hasOnly([
          'id', 'cueId', 'careProfileId', 'shiftId', 'title', 'instructions', 'importance',
          'assignedUserId', 'scheduledAt', 'status', 'acknowledgedAt', 'snoozedUntil',
          'blockedReason', 'createdAt', 'updatedAt'
        ]) &&
        data.id is string && data.cueId is string && (data.careProfileId == null || data.careProfileId is string) &&
        data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
        data.instructions is string && data.instructions.size() > 0 && data.instructions.size() <= 2000 &&
        data.importance in ['routine', 'important', 'critical'] &&
        (data.shiftId == null || data.shiftId is string) &&
        (data.assignedUserId == null || data.assignedUserId is string) &&
        data.scheduledAt is timestamp &&
        data.status in ['upcoming', 'due', 'completed', 'snoozed', 'blocked', 'skipped', 'overdue'] &&
        (data.acknowledgedAt == null || data.acknowledgedAt is timestamp) &&
        (data.snoozedUntil == null || data.snoozedUntil is timestamp) &&
        (data.blockedReason == null || (data.blockedReason is string && data.blockedReason.size() <= 500)) &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validPlaybookEntry(spaceId, data) {
      return data.keys().hasAll([
          'id', 'title', 'category', 'details', 'locationLabel', 'reminderAt',
          'assignedUserId', 'active', 'createdByUserId', 'createdAt', 'updatedAt'
        ]) &&
        data.keys().hasOnly([
          'id', 'title', 'category', 'details', 'locationLabel', 'reminderAt',
          'assignedUserId', 'active', 'createdByUserId', 'createdAt', 'updatedAt'
        ]) &&
        data.id is string && data.id.size() > 0 &&
        data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
        data.category in ['utilities', 'appliances', 'documents', 'contacts', 'emergency', 'general'] &&
        data.details is string && data.details.size() > 0 && data.details.size() <= 3000 &&
        (data.locationLabel == null || (data.locationLabel is string && data.locationLabel.size() <= 120)) &&
        (data.reminderAt == null || data.reminderAt is timestamp) &&
        (data.assignedUserId == null || (
          data.assignedUserId is string &&
          canReceiveAssignment(spaceId, data.assignedUserId)
        )) &&
        (data.reminderAt == null || data.assignedUserId != null) &&
        data.active is bool && data.createdByUserId is string &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validHandover(data) {
      return data.keys().hasAll([
          'id', 'transcript', 'summary', 'items', 'unresolvedQuestions', 'createdByUserId',
          'createdByDisplayName', 'createdAt', 'updatedAt'
        ]) &&
        data.keys().hasOnly([
          'id', 'transcript', 'summary', 'items', 'unresolvedQuestions', 'createdByUserId',
          'createdByDisplayName', 'provider', 'createdAt', 'updatedAt'
        ]) &&
        data.id is string && data.id.size() > 0 &&
        data.transcript is string && data.transcript.size() >= 12 && data.transcript.size() <= 8000 &&
        data.summary is string && data.summary.size() > 0 && data.summary.size() <= 2000 &&
        data.items is list && data.items.size() <= 20 &&
        data.unresolvedQuestions is list && data.unresolvedQuestions.size() <= 20 &&
        (!('provider' in data) || data.provider in ['openai', 'gemini', 'local-rules', 'local-fallback']) &&
        data.createdByUserId is string &&
        data.createdByDisplayName is string && data.createdByDisplayName.size() <= 100 &&
        data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function validActivityEvent(data) {
      return data.keys().hasAll(['id', 'type', 'summary', 'actorUserId', 'actorDisplayName', 'createdAt']) &&
        data.keys().hasOnly(['id', 'type', 'summary', 'actorUserId', 'actorDisplayName', 'createdAt']) &&
        data.id is string && data.id.size() > 0 &&
        data.type is string && data.type.size() > 0 && data.type.size() <= 60 &&
        data.summary is string && data.summary.size() > 0 && data.summary.size() <= 300 &&
        data.actorUserId is string &&
        data.actorDisplayName is string && data.actorDisplayName.size() <= 100 &&
        data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId &&
        validUser(request.resource.data) &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
      allow update: if signedIn() && request.auth.uid == userId &&
        validUser(request.resource.data) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email', 'displayName', 'photoUrl', 'updatedAt'
        ]);
      allow delete: if false;

      match /familySpaces/{spaceId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow create: if signedIn() && request.auth.uid == userId &&
          validUserSpace(spaceId, request.resource.data) &&
          request.resource.data.createdAt == request.time &&
          getAfter(/databases/$(database)/documents/familySpaces/$(spaceId)).data.name == request.resource.data.name &&
          getAfter(/databases/$(database)/documents/familySpaces/$(spaceId)).data.timezone == request.resource.data.timezone &&
          getAfter(/databases/$(database)/documents/familySpaces/$(spaceId)/members/$(userId)).data.role == request.resource.data.role &&
          getAfter(/databases/$(database)/documents/familySpaces/$(spaceId)/members/$(userId)).data.relationshipLabel == request.resource.data.relationshipLabel;
        allow update: if false;
        allow delete: if signedIn() && request.auth.uid == userId;
      }
    }

    match /familySpaces/{spaceId} {
      allow create: if signedIn() &&
        request.resource.data.id == spaceId &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        validFamilySpace(request.resource.data);
      allow read: if isMember(spaceId);
      allow update: if isOwner(spaceId) &&
        validFamilySpace(request.resource.data) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'timezone', 'updatedAt'
        ]);
      allow delete: if isOwner(spaceId);

      match /members/{userId} {
        allow read: if isMember(spaceId);
        // Additional members are created only by the trusted invitation endpoint.
        allow create: if signedIn() &&
          userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.role == 'owner' &&
          request.resource.data.joinedAt == request.time &&
          request.resource.data.updatedAt == request.time &&
          getAfter(/databases/$(database)/documents/familySpaces/$(spaceId)).data.ownerUid == request.auth.uid &&
          validFamilyMember(request.resource.data);
        allow update: if false;
        allow delete: if isOwner(spaceId) && resource.data.role != 'owner';
      }

      match /careProfiles/{profileId} {
        allow read: if isMember(spaceId);
        allow create: if canCoordinate(spaceId) &&
          request.resource.data.id == profileId &&
          request.resource.data.createdByUserId == request.auth.uid &&
          request.resource.data.createdAt == request.time &&
          request.resource.data.updatedAt == request.time &&
          validCareProfile(spaceId, request.resource.data);
        allow update: if canCoordinate(spaceId) &&
          validCareProfile(spaceId, request.resource.data) &&
          request.resource.data.updatedAt == request.time &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'fullName', 'preferredName', 'relationshipLabel', 'careNeedsSummary', 'status', 'updatedAt'
          ]);
        allow delete: if isOwner(spaceId);
      }

      match /instructions/{instructionId} {
        allow read: if isMember(spaceId);
        allow create: if canCoordinate(spaceId) &&
          request.resource.data.id == instructionId &&
          request.resource.data.createdByUserId == request.auth.uid &&
          request.resource.data.createdAt == request.time &&
          request.resource.data.updatedAt == request.time &&
          validCareRoutine(spaceId, request.resource.data);
        allow update: if canCoordinate(spaceId) &&
          validCareRoutine(spaceId, request.resource.data) &&
          request.resource.data.updatedAt == request.time &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'title', 'instructions', 'category', 'importance', 'timeOfDay', 'daysOfWeek', 'active', 'updatedAt'
          ]);
        allow delete: if canCoordinate(spaceId);
      }

      match /playbookEntries/{entryId} {
        allow read: if isMember(spaceId);
        allow create: if canContribute(spaceId) &&
          request.resource.data.id == entryId &&
          request.resource.data.createdByUserId == request.auth.uid &&
          request.resource.data.createdAt == request.time &&
          request.resource.data.updatedAt == request.time &&
          validPlaybookEntry(spaceId, request.resource.data);
        allow update: if canContribute(spaceId) &&
          validPlaybookEntry(spaceId, request.resource.data) &&
          request.resource.data.updatedAt == request.time &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'title', 'category', 'details', 'locationLabel', 'reminderAt', 'assignedUserId', 'active', 'updatedAt'
          ]);
        allow delete: if canCoordinate(spaceId);
      }

      match /careShifts/{shiftId} {
        allow read: if isMember(spaceId);
        allow create: if canCoordinate(spaceId) &&
          request.resource.data.id == shiftId &&
          request.resource.data.createdByUserId == request.auth.uid &&
          request.resource.data.status == 'pending' &&
          request.resource.data.acceptedAt == null &&
          request.resource.data.acceptedByUserId == null &&
          request.resource.data.declinedAt == null &&
          request.resource.data.declinedByUserId == null &&
          request.resource.data.createdAt == request.time &&
          request.resource.data.updatedAt == request.time &&
          validCareShift(spaceId, request.resource.data);
        allow delete: if canCoordinate(spaceId);
        allow update: if validCareShift(spaceId, request.resource.data) &&
          request.resource.data.updatedAt == request.time && (
          (canCoordinate(spaceId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'acceptedAt', 'acceptedByUserId', 'declinedAt', 'declinedByUserId', 'updatedAt'
            ])) || (
          signedIn() &&
          resource.data.status == 'pending' &&
          request.auth.uid in [resource.data.primaryUserId, resource.data.backupUserId] &&
          ((request.resource.data.status == 'accepted' &&
            request.resource.data.acceptedByUserId == request.auth.uid &&
            request.resource.data.acceptedAt == request.time &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'acceptedAt', 'acceptedByUserId', 'updatedAt'
            ])) ||
           (request.auth.uid != resource.data.declinedByUserId &&
            request.resource.data.declinedByUserId == request.auth.uid &&
            request.resource.data.declinedAt == request.time &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'declinedAt', 'declinedByUserId', 'updatedAt'
            ]) &&
            ((request.resource.data.status == 'pending' &&
              resource.data.backupUserId != null &&
              resource.data.declinedByUserId == null) ||
             (request.resource.data.status == 'declined' &&
              (resource.data.backupUserId == null ||
               (resource.data.declinedByUserId != null &&
                resource.data.declinedByUserId != request.auth.uid))))))
        ));
      }

      match /cues/{cueId} {
        allow read: if isMember(spaceId);
        // Cue definitions are currently derived from validated routines.
        allow create, update, delete: if false;
      }

      match /cueOccurrences/{occurrenceId} {
        allow read: if isMember(spaceId);
        allow create, delete: if false;
        allow update: if validCueOccurrence(request.resource.data) &&
          (canCoordinate(spaceId) || request.auth.uid == resource.data.assignedUserId) &&
          request.resource.data.updatedAt == request.time &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'acknowledgedAt', 'snoozedUntil', 'blockedReason', 'updatedAt'
          ]);
      }

      match /handovers/{handoverId} {
        allow read: if isMember(spaceId);
        allow create: if canContribute(spaceId) &&
          request.resource.data.id == handoverId &&
          request.resource.data.createdByUserId == request.auth.uid &&
          request.resource.data.createdAt == request.time &&
          request.resource.data.updatedAt == request.time &&
          validHandover(request.resource.data);
        allow update: if false;
        allow delete: if canCoordinate(spaceId);
      }

      match /documents/{documentId} {
        allow read: if isMember(spaceId);
        // Trusted Vault API routes verify membership and write metadata with Admin SDK.
        allow create, update, delete: if false;
      }

      match /deviceTokens/{tokenId} {
        // Background push is not part of the current client; keep this closed
        // until a trusted registration endpoint and token schema are added.
        allow read, create, update, delete: if false;
      }

      match /activityEvents/{eventId} {
        allow read: if isMember(spaceId);
        allow create: if canContribute(spaceId) &&
          request.resource.data.id == eventId &&
          request.resource.data.actorUserId == request.auth.uid &&
          request.resource.data.createdAt == request.time &&
          validActivityEvent(request.resource.data);
        allow update, delete: if false;
      }
    }

    // Invitation tokens and membership acceptance are handled by trusted server code.
    match /invitations/{invitationId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
